# Copie vers `.env` et/ou `.env.local` — le script `pnpm dynamic:create-wallet` charge les deux (`.env.local` surcharge `.env`).
# Jeton API serveur (Developer → API Tokens), pas un JWT utilisateur — ne jamais l’exposer au client.
DYNAMIC_AUTH_TOKEN=your_api_token_here
DYNAMIC_ENVIRONMENT_ID=your_environment_id_here
WALLET_PASSWORD=your_secure_wallet_password_here
